# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
SOURCE_CHANNEL=@flow_alerts_channel
DEST_CHANNEL=@my_decisions_channel

# ── Mode ──────────────────────────────────────────────────────────────────────
# true  = bypass market data, send HOLD immediately after hard filter (local testing)
# false = full production logic
TEST_MODE=false

# ── Intelligence layer ────────────────────────────────────────────────────────
# Channel A: bot posts structured YAML per flow here (all signals, pre-filter).
# Leave blank to disable Channel A output.
# INTEL_CHANNEL=-1001234567891

# How many signals must accumulate before a Channel B batch report fires.
# BATCH_SIGNAL_COUNT=3

# ── Tradier (option quote context) ────────────────────────────────────────────
# Get token at https://dash.tradier.com → API Access
# If not set, option quote fields stay None and bot runs normally.
# TRADIER_TOKEN=your_token_here

# ── Persistence ───────────────────────────────────────────────────────────────
# Optional: override DB path (Railway volume mount).
# DB_PATH=/app/data/signals.db

# Optional: private channel/group ID for Telegram-backed DB persistence.
# The bot must be admin with "Pin Messages" permission.
# On startup the bot restores the latest pinned backup; every 5 min it uploads a new one.
# Get the numeric ID by forwarding a message from the channel to @userinfobot.
# BACKUP_CHAT_ID=-1001234567890
